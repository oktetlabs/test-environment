    <script-template id="default_arg_test" name="default_args">
      <arg name="test_arg1" value="239"/>
      <arg name="test_arg2">
          <value>1</value>
          <value>2</value>
      </arg>
    </script-template>

    <script-template id="def_arg_test_bad_name" name="missing_test">
      <arg name="test_arg1" value="239"/>
      <arg name="test_arg2">
          <value>1</value>
          <value>2</value>
      </arg>
    </script-template>

    <script-template id="def_arg_test_wo_name">
      <arg name="test_arg1" value="239"/>
      <arg name="test_arg2">
          <value>1</value>
          <value>2</value>
      </arg>
    </script-template>

    <session track_conf="silent">
        <prologue>
            <script name="prologue"/>
            <arg name="env">
                <value>{{{'iut_rpcs':IUT}}}</value>
            </arg>
        </prologue>

        <run>
            <package name="minimal"/>
        </run>

        <run>
            <package name="tools"/>
        </run>

        <run>
            <package name="cs"/>
        </run>

        <run>
            <package name="tapi"/>
        </run>

        <run>
            <package name="rpc"/>
        </run>

        <run>
            <package name="apps"/>
        </run>

        <run>
            <package name="tad"/>
        </run>
    </session>

</package>
